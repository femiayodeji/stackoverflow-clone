{
  "name": "stackoverflow-clone",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:create": "sequelize-cli db:create",
    "db:migrate": "ts-node node_modules/.bin/sequelize-cli db:migrate",
    "db:rollback": "ts-node node_modules/.bin/sequelize-cli db:migrate:undo:all",
    "db:seed": "ts-node node_modules/.bin/sequelize-cli db:seed:all",
    "db:seed:undo": "ts-node node_modules/.bin/sequelize-cli db:seed:undo:all",
    "db:fresh": "npm run db:rollback && npm run db:migrate && npm run db:seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.2",
    "sequelize": "^6.37.8",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
